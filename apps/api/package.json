{
  "name": "@arena/api",
  "version": "0.0.1",
  "private": true,
  "description": "SABG backend: ingestion, engines, realtime gateway, payout bridge (build plan B1-B8, C4-C5).",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/mock/server.ts",
    "live:dev": "tsx watch src/live/run.ts",
    "gateway:dev": "tsx watch src/gateway/run.ts",
    "replay:dev": "tsx src/replay/run.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seeds/seed-matches.ts"
  },
  "dependencies": {
    "@arena/auth": "workspace:*",
    "@arena/contracts": "workspace:*",
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.98.0",
    "axios": "^1.7.7",
    "bs58": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "mongodb": "^7.4.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "tweetnacl": "^1.0.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.5",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
