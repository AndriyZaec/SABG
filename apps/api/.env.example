DATABASE_URL=postgres://arena:arena@localhost:5433/arena

# --- Realtime Gateway (src/gateway/**, `pnpm gateway:dev`) ---
# Production platforms may inject PORT; it takes precedence over GATEWAY_PORT.
GATEWAY_PORT=4000
# replay uses committed recorded events; live discovers an eligible World Cup fixture via TXODDS.
GAME_SOURCE=replay
# Production requires a non-default HMAC secret of at least 32 characters.
AUTH_SECRET=dev-insecure-auth-secret
CORS_ORIGINS=*
# Real seconds per match-minute for the recorded replay — the single speed knob. Paces the clock and
# the round countdown off the same rate, so open/lock/settle stay watchable and the countdown is
# truthful. Every round is a 5 match-minute window, so wall window = 5 x this (6 => 30s/round,
# ~8min for a full match). Small = compressed replay; ~60 = real-match pace.
GATEWAY_SECONDS_PER_MATCH_MINUTE=6
# Which recorded fixture the replay drives (must have a matching
# ingestion/__fixtures__/fixture-<id>.json). Default is the semi-final (England v Argentina);
# 18179764 (the final) is also available.
GATEWAY_REPLAY_FIXTURE_ID=18241006
# Opt-in continuous replay: final state stays visible for 2 minutes, then the cycle supervisor
# performs the guarded reset and starts a fresh 3-minute lobby. Never enabled for live feeds.
REPLAY_AUTO_RESTART=false
REPLAY_RESTART_DELAY_SECONDS=120
# Reset requires `--force --confirm-database=localhost:5433/arena`; its durable audit row is stored
# transactionally in PostgreSQL. This optional directory receives an additional immutable JSON copy.
# REPLAY_RESET_AUDIT_DIR=/opt/sabg/audit
# Optional production override; defaults to apps/web/dist relative to the compiled gateway.
# WEB_DIST_DIR=/absolute/path/to/apps/web/dist

# --- Live TXODDS SSE worker (src/live/**, `pnpm live:dev`) ---
# Devnet only (CLAUDE.md) — never put a mainnet key or real funds here.
SOLANA_NETWORK=devnet
SOLANA_WALLET_PRIVATE_KEY=
TXODDS_BASE_URL=https://txline-dev.txodds.com/api
# Optional override; production mounts a persistent file at /app/state/txline-cache.json.
# TXLINE_CACHE_FILE=/absolute/path/to/.txline-cache.json
# Optional World Cup fixture override. If unset, discovery requires exactly one current candidate.
# TXODDS_LIVE_FIXTURE_ID=18257865
MONGODB_URI=mongodb://localhost:27018/sabg_raw
MONGODB_DB=sabg_raw
LOG_LEVEL=info

# On-chain arena provisioning (backend as authority + payout_authority). Default off.
ONCHAIN_ARENAS_ENABLED=false
ARENA_RPC_URL=https://api.devnet.solana.com
# Keep this authority balance untouched after paying the next Arena PDA rent + transaction fee.
ARENA_AUTHORITY_RESERVE_LAMPORTS=50000000
# Service keypair (base58 or JSON array) — never commit a real value.
ARENA_AUTHORITY_SECRET=
