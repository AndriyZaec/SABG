DATABASE_URL=postgres://arena:arena@localhost:5433/arena

# --- Realtime Gateway (src/gateway/**, `pnpm gateway:dev`) ---
GATEWAY_PORT=4000
# Dev-only default (auth.ts's HMAC session-token secret) — set a real secret in prod.
AUTH_SECRET=dev-insecure-auth-secret
CORS_ORIGINS=*
# Optional: overrides B3's spec-§5 lead-time default (60s). NOTE: this only affects round.open's
# lockAt estimate for the *first* round of a match — every later round's estimate is dominated by
# a separate, hardcoded "1 match-minute ~= 60 real seconds" assumption in round-engine/engine.ts
# (see its RoundLifecycleEvent doc comment), which this setting cannot override. Under
# GATEWAY_REPLAY_DELAY_MS pacing below, that assumption is simply wrong: lockAt will typically
# read "~5 real minutes remaining" while the round actually locks in a few real seconds (fast
# pacing) or takes much longer (slow pacing). This is a known, undocumented-until-now limitation
# of the demo's accelerated replay, not a bug in the engine (which already documents lockAt as
# "estimate only, never authoritative") or in production/live-feed usage (where the real-time
# assumption holds). Don't build a precise client countdown off lockAt while testing the demo —
# only the actual round.lock/round.settle events are ever authoritative.
# GATEWAY_LEAD_TIME_SECONDS=5
# Wall-clock delay (ms) between demo fixture messages (gateway/run.ts) — 0 replays instantly.
GATEWAY_REPLAY_DELAY_MS=200

# --- Live TXODDS SSE worker (src/live/**, `pnpm live:dev`) ---
# Devnet only (CLAUDE.md) — never put a mainnet key or real funds here.
SOLANA_NETWORK=devnet
SOLANA_WALLET_PRIVATE_KEY=
TXODDS_BASE_URL=https://api.txodds.com
TXODDS_LIVE_FIXTURE_ID=18179764
MONGODB_URI=mongodb://localhost:27018/sabg_raw
MONGODB_DB=sabg_raw
LOG_LEVEL=info

# On-chain arena provisioning (backend as authority + payout_authority). Default off.
ONCHAIN_ARENAS_ENABLED=false
ARENA_RPC_URL=https://api.devnet.solana.com
# Service keypair (base58 or JSON array) — never commit a real value.
ARENA_AUTHORITY_SECRET=
