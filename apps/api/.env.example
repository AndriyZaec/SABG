DATABASE_URL=postgres://arena:arena@localhost:5433/arena

# --- Realtime Gateway (src/gateway/**, `pnpm gateway:dev`) ---
# Production platforms may inject PORT; it takes precedence over GATEWAY_PORT.
GATEWAY_PORT=4000
# Production requires a non-default HMAC secret of at least 32 characters.
AUTH_SECRET=dev-insecure-auth-secret
CORS_ORIGINS=*
# Real seconds per match-minute for the demo replay — the single speed knob. Paces the clock and
# the round countdown off the same rate, so open/lock/settle stay watchable and the countdown is
# truthful. Every round is a 5 match-minute window, so wall window = 5 x this (6 => 30s/round,
# ~8min for a full match). Small = compressed demo; ~60 = real-match pace.
GATEWAY_SECONDS_PER_MATCH_MINUTE=6
# Which recorded fixture the demo replay drives (must have a matching
# ingestion/__fixtures__/fixture-<id>.json). Default is the semi-final (England v Argentina);
# 18179764 (the final) is also available.
GATEWAY_DEMO_FIXTURE_ID=18241006
# Optional production override; defaults to apps/web/dist relative to the compiled gateway.
# WEB_DIST_DIR=/absolute/path/to/apps/web/dist

# --- Live TXODDS SSE worker (src/live/**, `pnpm live:dev`) ---
# Devnet only (CLAUDE.md) — never put a mainnet key or real funds here.
SOLANA_NETWORK=devnet
SOLANA_WALLET_PRIVATE_KEY=
TXODDS_BASE_URL=https://api.txodds.com
TXODDS_LIVE_FIXTURE_ID=18179764
MONGODB_URI=mongodb://localhost:27018/sabg_raw
MONGODB_DB=sabg_raw
LOG_LEVEL=info

# On-chain arena provisioning (backend as authority + payout_authority). Default off.
ONCHAIN_ARENAS_ENABLED=false
ARENA_RPC_URL=https://api.devnet.solana.com
# Service keypair (base58 or JSON array) — never commit a real value.
ARENA_AUTHORITY_SECRET=
