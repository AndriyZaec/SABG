# URL-encode reserved characters in the password used in this URL.
DATABASE_URL=postgres://arena_app:REPLACE_APP_DATABASE_PASSWORD@postgres:5432/arena

NODE_ENV=production
GAME_SOURCE=replay
SOLANA_NETWORK=devnet

AUTH_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
AUTH_REQUIRE_SIGNATURE=true
CORS_ORIGINS=*

GATEWAY_REPLAY_FIXTURE_ID=18241006
GATEWAY_LOBBY_SECONDS=180
GATEWAY_SECONDS_PER_MATCH_MINUTE=6

REPLAY_AUTO_RESTART=true
REPLAY_RESTART_DELAY_SECONDS=120
REPLAY_RESET_AUDIT_DIR=/app/audit

# Required when GAME_SOURCE=live. URL-encode any reserved characters in the password.
# The Mongo user is created by deploy/mongo-init.sh.
MONGODB_URI=mongodb://arena_ingest:REPLACE_MONGO_APP_PASSWORD@mongo:27017/sabg_raw?authSource=sabg_raw
MONGODB_DB=sabg_raw
TXLINE_CACHE_FILE=/app/state/txline-cache.json
SOLANA_WALLET_PRIVATE_KEY=REPLACE_WITH_DEDICATED_TXLINE_DEVNET_WALLET
TXODDS_BASE_URL=https://txline-dev.txodds.com/api
# Set explicitly for match day after checking the sanitized World Cup snapshot.
# TXODDS_LIVE_FIXTURE_ID=

ONCHAIN_ARENAS_ENABLED=true
ARENA_RPC_URL=https://api.devnet.solana.com
ARENA_AUTHORITY_SECRET=REPLACE_WITH_DEDICATED_DEVNET_AUTHORITY
ARENA_AUTHORITY_RESERVE_LAMPORTS=50000000

LOG_LEVEL=info
