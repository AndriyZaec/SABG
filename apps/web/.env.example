# Development defaults to the in-process mock. Production defaults to the same-origin real gateway
# when this variable is unset; explicitly setting "true" keeps the mock even in a production build.
VITE_MOCK_API=true

# Solana RPC for the wallet/program client. Defaults to devnet if unset.
VITE_SOLANA_RPC=https://api.devnet.solana.com
