{
  "name": "@arena/contracts",
  "version": "0.0.1",
  "private": true,
  "description": "Shared types & contracts for SABG / Fan Battle Royale (entities, enums, DTOs, WS messages, settlement DSL).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./onchain": {
      "types": "./dist/onchain/index.d.ts",
      "default": "./dist/onchain/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "idl:sync": "cp ../../programs/arena/target/idl/arena.json src/onchain/arena.idl.json && cp ../../programs/arena/target/types/arena.ts src/onchain/arena.ts"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
